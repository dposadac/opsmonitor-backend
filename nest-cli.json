{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/events/src",
  "monorepo": true,
  "root": "apps/events",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "apps/events/tsconfig.app.json"
  },
  "projects": {
    "events": {
      "type": "application",
      "root": "apps/events",
      "entryFile": "main",
      "sourceRoot": "apps/events/src",
      "compilerOptions": {
        "tsConfigPath": "apps/events/tsconfig.app.json"
      }
    },
    "incidents": {
      "type": "application",
      "root": "apps/incidents",
      "entryFile": "main",
      "sourceRoot": "apps/incidents/src",
      "compilerOptions": {
        "tsConfigPath": "apps/incidents/tsconfig.app.json"
      }
    },
    "alerts": {
      "type": "application",
      "root": "apps/alerts",
      "entryFile": "main",
      "sourceRoot": "apps/alerts/src",
      "compilerOptions": {
        "tsConfigPath": "apps/alerts/tsconfig.app.json"
      }
    },
    "repository": {
      "type": "library",
      "root": "libs/repository",
      "entryFile": "index",
      "sourceRoot": "libs/repository/src",
      "compilerOptions": {
        "tsConfigPath": "libs/repository/tsconfig.lib.json"
      }
    }
  }
}
